function noctugenesis_2_gibberish(p: player):
    set {_book} to a written book named "|\|ГёcвҖ В·|В·gГ«|\|Г«В§В·|В·В§  I  I"
    set author of {_book} to "|В·|В·|В·В§вҖ ГёВҰВ·|В·В·|\|"

    set {_p1} to ""
    add "Гғ|\|d  lГё\/Г«d  lВ·|В·Ж’Г«  В·|В·вҖ   dВ·|В·d;" to {_p1}
    add "%nl%%nl%В·|В·вҖ   ВҰГёВ·|В·|В·|Г«d  вҖ |В·|Г«  lВ·|В·|\|dВ§  В·|В·|\|d  Г«|\|gВ·|В·lЖ’Г«d  В·|В·вҖ   Ж’В·|В·llГҝ;" to {_p1}
    add "%nl%%nl%В·|В·вҖ   ВҰВ·|В·lГ«d  lВ·|В·Ж’Г«  В·|В·В§  В·|В·  Ж’В·|В·вҖ |В·|Г«ВҰ  вҖ Гё  В·|В·  c|В·|В·|В·ld;" to {_p1}
    add "%nl%%nl%Гғ|\|d  В·|В·вҖ   gВҰГ«\/\/  Г«|\|bВ·|В·ГёВ·|В·В§  ГёЖ’  вҖ |В·|Г«  &5|\|В·|В·g|В·|вҖ &rвҖҷВ§  |В·|В·|В·|В·g|В·|вҖ ;" to {_p1}

    set {_p2} to ""
    add "FВ·|В·Г«ВҰcГ«  \/\/В·|В·вҖ |В·|  |В·|В·|В·bВҰВ·|В·В§,  вҖ |В·|Г«  &4|В·|В·Г«В·|В·вҖ &r  В§ГёВ·|В·g|В·|вҖ   |В·|В·|ГёВҰГ«;" to {_p2}
    add "%nl%%nl%DВ·|В·В§В§В·|В·вҖ В·|В·В§Ж’В·|В·Г«d  \/\/В·|В·вҖ |В·|  В§|В·|В·|В·ВҰВ·|В·|\|g  lВ·|В·Ж’Г«вҖҷВ§  ВҰГ«В·|В·g|\|," to {_p2}
    add "%nl%%nl%В·|В·вҖ   В§ГёВ·|В·g|В·|вҖ   вҖ Гё  bГ«  cВҰГё\/\/|\|Г«d  В§ГёlГ«  ВҰВ·|В·lГ«ВҰ;" to {_p2}
    add "%nl%%nl%TГё  ВҰВ·|В·lГ«  |\|ГёвҖ   jВ·|В·В§вҖ   вҖ |В·|Г«  В§Г«В·|В·  В·|В·|\|d  вҖ |В·|Г«  lВ·|В·|\|d,  bВ·|В·вҖ   вҖ |В·|Г«  В§ kГҝ  вҖ ГёГё;" to {_p2}

    set {_p3} to ""
    add "T|В·|В·|В·В§  вҖ |В·|Г«  &5|\|В·|В·g|В·|вҖ &r  bВҰГёВ·|В·g|В·|вҖ   cВ·|В·lВ·|В·|В·|В·|В·вҖ Гҝ  В·|В·|В·Гё|\|  вҖ |В·|Г«  Г«В·|В·ВҰвҖ |В·|;" to {_p3}
    add "%nl%MГёВ·|В·|\|вҖ В·|В·В·|В·|\|В§  clВ·|В·В§|В·|Г«d,  |В·|В·|Гё\/В·|В·|\|g  В·|В·bГёВ·|В·вҖ   В·|В·В§  вҖ |В·|ГёВ·|В·g|В·|  lВ·|В·\/В·|В·|\|g;" to {_p3}
    add "%nl%%nl%T|В·|Г«  В§Г«В·|В·В§  ВҰГёВ·|В·ВҰГ«d,  \/\/В·|В·\/Г«В§  ВҰВ·|В·В§В·|В·|\|g |В·|В·|В·g|В·|Г«ВҰ  вҖ |В·|В·|В·|\|  вҖ |В·|Г«  В§ kГҝ;" to {_p3}
    add "%nl%%nl%LВ· |В·\/В·|В·  В§В·|В·ВҰgГ«d  Ж’ВҰГё|В·|В·|  вҖ |В·|Г«  gВҰГёВ·|В·|\|d,  В§Г«В·|В·В§  ГёЖ’  dГ«В·|В·dlГҝ  |В·|В·|llГё\/\/;" to {_p3}

    set {_p4} to ""
    add "GВ·|В·В·|В·|\|вҖ ,  вҖ В·|В·вҖ В·|В·|\|ГёВ·|В·В§,  Г«|\|dlГ«В§В§,  Г«|\|ГёВҰ|В·|В·|ГёВ·|В·В§  \/\/В·|В·llВ§  ГёЖ’  &5|\|В·|В·g|В·|вҖ &r  Г«|В·|В·|Г«ВҰgГ«d;" to {_p4}
    add "%nl%MВ·|В·ВҰkВ·|В·|\|g  В·|В·|В·|В·|В·Г«|\|Г«вҖ ВҰВ·|В·blГ«  bГёВҰdГ«ВҰВ§  bГ«вҖ \/\/Г«Г«|\|  вҖ |В·|Г«  |\|Г«\/\/lГҝ  dВ·|В·\/В·|В·dГ«d  Г«В·|В·ВҰвҖ |В·|;" to {_p4}
    add "%nl%%nl%EВ·|В·c|В·|  lВ·|В·|\|d,  В·|В·  В§Г«В·|В·В·|В·ВҰВ·|В·вҖ Г«d  \/\/ГёВҰld  ГёЖ’  В·|В·вҖ В§  Гё\/\/|\|;" to {_p4}
    add "%nl%%nl%WВ·|В·вҖ |В·|  В·|В·вҖ В§  Гё\/\/|\|  Ж’ГёВҰГ«В§вҖ ,  В·|В·вҖ В§  Гё\/\/|\|  В§Г«В·|В·,  В·|В·вҖ В§  Гё\/\/|\|  lВ·|В·Ж’Г«  В·|В·|\|d  В·|В·вҖ В§  Гё\/\/|\|  В§В·|В·|\|;" to {_p4}

    set {_p5} to ""
    add "T|В·|В·|В·В§  вҖ |В·|Г«  &5|\|В·|В·g|В·|вҖ &r  bВҰГёВ·|В·g|В·|вҖ   |В·|В·|В·|\|В·|В·В§|В·|В·|В·|Г«|\|вҖ   В·|В·|В·Гё|\|  вҖ |В·|Г«  &4В§В·|В·|\|&r;" to {_p5}
    add "%nl%%nl%FГёВҰ  dГ«В§В·|В·ВҰВ·|В·|\|g  вҖ Гё  ВҰВ·|В·lГ«  В·|В·ll  lВ·|В·Ж’Г«,  lВ·|В·Ж’Г«  \/\/В·|В·В§  |\|Гё\/\/  В§Г«В·|В·В·|В·ВҰВ·|В·вҖ Г«d;" to {_p5}
    add "%nl%EВ·|В·c|В·|  lВ·|В·Ж’Г«  В·|В·вҖ В§  Гё\/\/|\|  lВ·|В·|\|d,  В·|В·вҖ В§  Гё\/\/|\|  |В·|В·|В·ВҰвҖ   ГёЖ’  вҖ |В·|Г«  &4В§В·|В·|\|&r;" to {_p5}
    add "%nl%%nl%Гғ  |В·|В·|В·ВҰвҖ   ГёЖ’  вҖ |В·|Г«  &4В§В·|В·|\|&r  вҖ ВҰВ·|В·|В·|В·Г«d  \/\/В·|В·вҖ |В·|В·|\|  вҖ |В·|Г«  dВ·|В·\/В·|В·dГ«;" to {_p5}

    set {_p6} to ""
    add "Гғ|\|d  вҖ |В·|Г«  &4В§В·|В·|\|&r  \/\/В·|В·В§  \/\/ВҰВ·|В·вҖ |В·|;" to {_p6}
    add "%nl%%nl%Гғ|\|d  вҖ |В·|Г«  &4В§В·|В·|\|&r  \/\/В·|В·В§  \/Г«|\|gГ«В·|В·|\|cГ«;" to {_p6}
    add "%nl%%nl%Гғ|\|d  вҖ |В·|Г«  &4В§В·|В·|\|&r  \/\/В·|В·В§  &4&l|В·|В·|В·вҖ Г«&r." to {_p6}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}
    set page 4 of {_book} to {_p4}
    set page 5 of {_book} to {_p5}
    set page 6 of {_book} to {_p6}

    give {_book} to {_p}

