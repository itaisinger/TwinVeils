function ruminations_ii_book(p: player):
    set {_book} to a written book named "Ruminations II"
    set author of {_book} to "Sigibert"

    # Page 1: The Intro
    set {_p1} to ""
    add "O Night," to {_p1}
    add "%nl%%nl%Why thou left thy kin to rubble, while thou roams the endless night?" to {_p1}

    # Page 2: The Long Sentence (Split for space)
    set {_p2} to ""
    add "Why thou deserted thy servants to a tomb of stone and gravel,%nl%%nl%while thy estranged stays by the side of his kin in the desert sun?" to {_p2}

    # Page 3: The Severing
    set {_p3} to ""
    add "O Night," to {_p3}
    add "%nl%%nl%Why did thou sever the world to pieces?" to {_p3}
    add "%nl%%nl%For the sinner - the sun - is left to roam the different seas,%nl%%nl%but thy servants are left to a life of separated solitude?" to {_p3}

    # Page 4: The Egg
    set {_p4} to ""
    add "O Night," to {_p4}
    add "%nl%%nl%What will be of thy kin when thy time has come?" to {_p4}
    add "%nl%%nl%&oWhen thy egg of darkness is shone nether red;&r" to {_p4}
    add "%nl%%nl%What will hatch out of the shed?" to {_p4}

    # Page 5: The Judgment
    set {_p5} to ""
    add "Will another set of wings spread and leave us once more?" to {_p5}
    add "%nl%%nl%Or will the lord of truth keep us company?" to {_p5}
    add "%nl%%nl%will it judge us to an eternity of slumber," to {_p5}
    add "%nl%%nl%As thou has once did?" to {_p5}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}
    set page 4 of {_book} to {_p4}
    set page 5 of {_book} to {_p5}

    give {_book} to {_p}

