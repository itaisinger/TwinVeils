function sea_passage_gibberish(p: player):
    set {_book} to a written book named "PВ·|В·В§В§|В·|ВҰВ·gГ«  ГёЖ’  TВ·|В·dГ«В§"
    set author of {_book} to "K|В·|ВҰВ·zВ·|В·|\|В·|В·ГҜВ·|В·"

    # Real text:
    # O Tide;
    # Mirror of the Sun;
    # Ra.
    set page 1 of {_book} to "Гҳ В TВ·|В·dГ«;%nl%%nl%MВ·|В·ВҰВҰГёВҰ В ГёЖ’ В вҖ |В·|Г« В В§В·|В·|\|;%nl%%nl%%nl%&3&lRВ·|В·ГҘ.%nl%%nl%"

    # Real text:
    # Wash away the sins of the Night;
    # Let the salt cleanse our wounds;
    # As the Sun kisses the horizon,
    # we drift towards salvation.
    set page 2 of {_book} to "WВ·|В·В§|В·| В В·|В·\/\/В·|В·Гҝ В вҖ |В·|Г« В В§В·|В·|\|В§ В ГёЖ’ В вҖ |В·|Г« В |\|В·|В·g|В·|вҖ ;%nl%LГ«вҖ  В вҖ |В·|Г« В В§В·|В·lвҖ  В clГ«В·|В·|\|В§Г« В ГёВ·|В·ВҰ В \/\/ГёВ·|В·|\|dВ§;%nl%%nl%ГғВ§ В вҖ |В·|Г« В В§В·|В·|\| В kВ·|В·В§В§Г«В§ В вҖ |В·|Г« В |В·|ГёВҰВ·|В·zГё|\|,%nl%\/\/Г« В dВҰВ·|В·Ж’вҖ  В вҖ Гё\/\/В·|В·ВҰdВ§ В В§В·|В·l\/В·|В·вҖ В·|В·Гё|\|."

    # Real text:
    # For the depths are dark,
    # but thy surface reflects the light;
    # O Sea, embrace us;
    # For we belong to the waves.
    set page 3 of {_book} to "FГёВҰ В вҖ |В·|Г« В dГ«В·|В·вҖ |В·|В§ В В·|В·ВҰГ« В dВ·|В·ВҰk,%nl%bВ·|В·вҖ  В вҖ |В·|Гҝ В В§В·|В·ВҰЖ’В·|В·cГ« В ВҰГ«Ж’lГ«cвҖ В§ В вҖ |В·|Г« В lВ·|В·g|В·|вҖ ;%nl%%nl%&3Гҳ В SГ«В·|В·, В Г«|В·|bВҰВ·|В·cГ« В В·|В·|В·В§;&r%nl%FГёВҰ В \/\/Г« В bГ«lГё|\|g В вҖ Гё В вҖ |В·|Г« В \/\/В·|В·\/Г«В§."

    give {_book} to {_p}
#
function lost_sailor(p: player):
    set {_book} to a written book named "Lost Note"
    set author of {_book} to "Iaru of Per Mesket"

    set {_p1} to ""
    add "O sea;" to {_p1}
    add "%nl%%nl%Breath wind in the sails of whoever finds this note;" to {_p1}
    add "%nl%%nl%For my sails could bare no longer;" to {_p1}
    add "%nl%%nl%They sunk back to thee, along with the remaining planks;" to {_p1}

    set {_p2} to ""
    add "Ironic," to {_p2}
    add "%nl%That I may find my demise at lost of water, where the infinite sea spreads before me;" to {_p2}
    add "%nl%%nl%O sea;" to {_p2}
    add "%nl%Help whoever treads here after my time has come;" to {_p2}

    set {_p3} to ""
    add "Help them fulfil what I have envisioned;" to {_p3}
    add "%nl%%nl%The prophecy of the three heads;" to {_p3}
    add "%nl%%nl%At last, not a fever dream, but a vivid reality;" to {_p3}

    set {_p4} to ""
    add "Before my eyes, just north east of this estranged shores;" to {_p4}
    add "%nl%%nl%Lay the first temple of grief;" to {_p4}
    add "%nl%%nl%The tomb of &lSekhmet&r." to {_p4}

    set {_p5} to ""
    add "O sea, bless this lost traveler who comes after me;" to {_p5}
    add "%nl%%nl%For my mission has bested me,%nl%but he might sail through in my stead;" to {_p5}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}
    set page 4 of {_book} to {_p4}
    set page 5 of {_book} to {_p5}

    give {_book} to {_p}