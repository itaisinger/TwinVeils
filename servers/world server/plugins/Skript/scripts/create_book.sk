command /give_book <text>:
    permission: op
    trigger:
        if arg-1 is "dawn":
            morning_passage(player)
        if arg-1 is "dawn sea":
            morning_passage_sea(player)
        if arg-1 is "lost_traveler":
            lost_traveler(player)
        if arg-1 is "ra_birth":
            ra_birth(player)
        if arg-1 is "khazamir":
            khazamir_story(player)
        if arg-1 is "gibrish":
            gibrish(player)
        if arg-1 is "genesis 1":
            noctugenesis_1(player)
        if arg-1 is "genesis 2":
            noctugenesis_2(player)
        if arg-1 is "genesis 2 gibrish":
            noctugenesis_2_gibberish(player)
        if arg-1 contains "sea g":
            sea_passage_gibberish(player)
        if arg-1 contains "lost sailor":
            lost_sailor(player)
        if arg-1 is "3heads":
            prophecy_three_heads(player)
        if arg-1 is "dawn snow":
            morning_passage_snow(player)

function morning_passage(p: player):
    set {_book} to a written book named "Passage of Dawn"
    set author of {_book} to "Khazamir"
    # Paste your long text below
    set page 1 of {_book} to "O heat;%nl%%nl%Morning star, lord of the sun;%nl%%nl%%nl%&4&lRa.%nl%%nl%"
    set page 2 of {_book} to "Let thy light shine upon thy servants once more;%nl%A thousand rays, pure force of enlightenment;%nl%%nl%Keep us within thy sake; devour the remnants of the night;%nl%A pillar of fire, shining bright since dawn of earth;"
    set page 3 of {_book} to "Show us the way, light the path forward;%nl%%nl%And when thy path is to the ground, back to the place of birth;%nl%%nl%As the sun sinks under at the edge of day, too shall we;%nl%%nl%From below we came, and thus shall we at last return;"
    set page 4 of {_book} to "&4O heat, hear us;&r%nl%For we scream with lungs aflame;%nl%%nl%&4O heat, save us;&r%nl%For we weak to nights of terror;%nl%%nl%&4O heat, love us;&r%nl%For Aten is a harsh, and a cruel, and a cold mistress;%nl%And the heat gives us power to keep on."
    give {_book} to {_p}

function morning_passage_sea(p: player):
    set {_book} to a written book named "Passage of Dawn"
    set author of {_book} to "Khazamir of Sahra"
    # Paste your long text below
    set page 1 of {_book} to "O sea;%nl%%nl%Tidal wave, lord of the sun;%nl%%nl%%nl%&4&lRa.%nl%%nl%"
    set page 2 of {_book} to "Let thy light shine upon thy servants once more;%nl%A thousand rays, pure force of enlightenment;%nl%%nl%Keep us within thy sake; devour the remnants of the night;%nl%A pillar of fire, shining bright since dawn of earth;"
    set page 3 of {_book} to "Show us the way, light the way back ashore;%nl%%nl%And when thy path is to the depths, back to the place of birth;%nl%%nl%As the sun sinks under behind the waves, too shall we;%nl%%nl%From below we came, and thus shall we at last return;"
    set page 4 of {_book} to "&4O sea, hear our calls;&r%nl%For our screams are drowned by the endless depths;%nl%%nl%But the Sun give us power to rise back up."
    give {_book} to {_p}

function lost_traveler(p: player):
    set {_book} to a written book named "My final pilgrimage"
    set author of {_book} to "Narith"
    set page 1 of {_book} to "O heat,%nl%Too far from thy path I've ridden%nl%%nl%The journey is weary and vengeful, why shan't thee show me thy pillar of flame?%nl%%nl%The curse of the traveler is upon me, and Diya al-Sahra is nowhere in sight"
    set page 2 of {_book} to "O heat, hear me, for I scream with lungs aflame,%nl%%nl%O heat, save me, for I weak to a night of terror,%nl%%nl%O heat, love me, cause I fear thy love is the last for me"
    give {_book} to {_p}

function noctugenesis_1(p: player):
    set {_book} to a written book named "Noctugenesis I"
    set author of {_book} to "Historian"

    set {_p1} to ""
    add "Once there was only the Night;" to {_p1}
    add "%nl%The Night was eternal; it was everywhere and nowhere;" to {_p1}
    add "%nl%%nl%The Night was the moon; It was the darkness beyond;" to {_p1}
    add "%nl%The Night was cold, and dark, and alive;" to {_p1}
    add "%nl%%nl%And the Night was named &5&lKhonsu&r." to {_p1}

    set {_p2} to ""
    add "Once the Night was lonely;" to {_p2}
    add "%nl%Thus he created land; forests, and mountains and deserts;" to {_p2}
    add "%nl%%nl%Thus he created sea; endless blue, sky upon earth;" to {_p2}
    add "%nl%Thus he created life; Birds and fish and the first men." to {_p2}
    add "%nl%%nl%And the Night was satisfied." to {_p2}

    set {_p3} to ""
    add "But life was lonely;" to {_p3}
    add "%nl%The Night lived time as he pleases;" to {_p3}
    add "%nl%%nl%While life lived through time as men do;" to {_p3}
    add "%nl%%nl%Thus the Night envisioned the Sun." to {_p3}

    set {_p4} to ""
    add "A warm heat, one that'll keep life company;" to {_p4}
    add "%nl%%nl%One that'll hear life’s calls;" to {_p4}
    add "%nl%One that'll keep life warm;" to {_p4}
    add "%nl%One that'll keep life safe;" to {_p4}
    add "%nl%%nl%One that'll love life with all its might." to {_p4}
    
    set {_p45} to ""
    add "%nl%%nl%%nl%%nl%%nl%%nl%And the heat’s name was &4&lRa&r." to {_p45}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}
    set page 4 of {_book} to {_p4}
    set page 5 of {_book} to {_p45}
    set page 6 of {_book} to {_p5}

    give {_book} to {_p}

function noctugenesis_2(p: player):
    set {_book} to a written book named "Noctugenesis II"
    set author of {_book} to "Historian"

    set {_p0} to ""
    add "And loved life the Sun did;" to {_p0}
    add "%nl%%nl%It roamed the lands and engulfed it fully;" to {_p0}
    add "%nl%%nl%It ruled life as a father to a child;" to {_p0}
    add "%nl%%nl%And it grew envious of the Night’s might;" to {_p0}

    set {_p1} to ""
    add "Fierce with hubris, the heat sought more;" to {_p1}
    add "%nl%%nl%Dissatisfied with sharing life’s reign," to {_p1}
    add "%nl%%nl%It sought to be crowned sole ruler;" to {_p1}
    add "%nl%%nl%To rule not just the sea and the land, but the sky too;" to {_p1}

    set {_p2} to ""
    add "Thus the Night brought calamity upon the earth;" to {_p2}
    add "%nl%Mountains clashed, moving about as though living;" to {_p2}
    add "%nl%%nl%The seas roared, waves rising higher than the sky;" to {_p2}
    add "%nl%%nl%Lava surged from the ground, seas of deadly hallow;" to {_p2}

    set {_p3} to ""
    add "Giant, titanous, endless, enormous walls of Night emerged;" to {_p3}
    add "%nl%Marking impenetrable borders between the newly divided earth;" to {_p3}
    add "%nl%%nl%Each land, a separated world of its own;" to {_p3}
    add "%nl%%nl%With its own forest, its own sea, its own life and its own sun;" to {_p3}

    set {_p4} to ""
    add "Thus the Night brought punishment upon the sun;" to {_p4}
    add "%nl%%nl%For desiring to rule all life, life was now separated;" to {_p4}
    add "%nl%Each life its own land, its own part of the sun;" to {_p4}
    add "%nl%%nl%A part of the sun trapped within the divide;" to {_p4}

    set {_p5} to ""
    add "And the sun was wrath;" to {_p5}
    add "%nl%%nl%And the sun was vengeance;" to {_p5}
    add "%nl%%nl%And the sun was hate." to {_p5}

    set page 1 of {_book} to {_p0}
    set page 2 of {_book} to {_p1}
    set page 3 of {_book} to {_p2}
    set page 4 of {_book} to {_p3}
    set page 5 of {_book} to {_p4}
    set page 6 of {_book} to {_p5}

    give {_book} to {_p}

function ra_birth(p: player):
    set {_book} to a written book named "Flame of Creation"
    set author of {_book} to "Khazamir"

    set {_p1} to ""
    add "Here hatched the sun;" to {_p1}
    add "%nl%A magnificent sight to behold -"  to {_p1}

    add "%nl%%nl%   The marvel of       creation;" to {_p1}
    add "%nl%%nl%Here &5life&r created &4life&r," to {_p1}
    add "%nl%       The first &oother;"  to {_p1}

    set {_p2} to ""
    add "&4O heat,&r the sea burns at your welcome," to {_p2}
    add "%nl%The world yet years for your lust;" to {_p2}
    add "%nl%%nl%&4O heat&r, breath fire upon these walls of night," to {_p2}
    add "%nl%Set fire to the dark, consume what was lost to time;" to {_p2}

    set {_p3} to ""
    add "%nl%%nl%%nl%&4O heat&r, burn it all down;%nl%%nl%For from darkness the world was born,%nl%%nl%But light is stronger." to {_p3}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}

    give {_book} to {_p}


function khazamir_story(p: player):

    set {_book} to a written book named "The Tale of Khazamir the Blind"
    set author of {_book} to "Jawfar"

    set {_p1} to ""
    add "O heat,%nl%hear thy story of long ago;" to {_p1}
    add "%nl%%nl%A story from before the rebirth of the world;" to {_p1}
    add "%nl%%nl%The story of &lKhazamir the Blind" to {_p1}

    set {_p2} to ""
    add "In the town of Siba’ara which was lost to time;" to {_p2}
    add "%nl%Zafirah was a wife of a mine worker;" to {_p2}
    add "%nl%%nl%Living under the land, Khazamir’s mother was ignorant to the sun’s bliss;" to {_p2}
    add "%nl%And thus, light didn’t reach her womb, and her firstborne child was blind;" to {_p2}

    set {_p3} to ""
    add "Disabled, Khazamir was unable to work his bread;" to {_p3}
    add "%nl%He was a liability and an outcast;" to {_p3}
    
    set {_p4} to ""
    add "When calamity fall upon Sahra, and the world was torn to pieces;" to {_p4}
    add "%nl%%nl%Fire surged from beneath the earth;" to {_p4}
    add "%nl%Mountains rose as if coming to life;" to {_p4}
    add "%nl%%nl%The morning star was restless in choosing a leader." to {_p4}
    
    set {_p5} to ""
    add "Astonished, light had befelled Khazamir’s eyes;" to {_p5}
    add "%nl%%nl%A miracle, a favor bestowed from the sun god himself;" to {_p5}
    add "%nl%%nl%The heat has chosen him to lead the newly broken Sahra." to {_p5}

    set {_p6} to ""
    add "Formerly blind, the walls of night didn’t scare him;" to {_p6}
    add "%nl%%nl%Formerly weak, his lust for power was undermined with lust for affection;" to {_p6}
    add "%nl%%nl%Formerly ignorant, his faith was ever powerful, unveiled to a miracle;" to {_p6}

    set {_p7} to ""
    add "Khazamir has led Sahra gallantry to prosperity;" to {_p7}
    add "%nl%%nl%He was the torch in the dark, he was the heat’s pillar of flame;" to {_p7}
    add "%nl%%nl%130 years he ruled the desert, before the sun has claimed him back;" to {_p7}
    
    set {_p8} to ""
    add "Once blind, from his tomb he will eternally overlook the beautiful sea;" to {_p8}
    add "%nl%%nl%%nl%And be washed by the waves, and the all encompassing sun;" to {_p8}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}
    set page 4 of {_book} to {_p4}
    set page 5 of {_book} to {_p5}
    set page 6 of {_book} to {_p6}
    set page 7 of {_book} to {_p7}
    set page 8 of {_book} to {_p8}

    give {_book} to {_p}

