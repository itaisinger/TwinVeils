function eschatology_book(p: player):
    set {_book} to a written book named "Eschatology IV"
    set author of {_book} to "Sigibert"
    set {_c} to "<#012a39>"

    set {_p1} to ""
    add "&oWhat does thou see, when one dares peek beyond velvet curtains?" to {_p1}

    set {_p2} to ""
    add "Onto the long night;" to {_p2}
    add "%nl%%nl%Onto fever dreams;" to {_p2}
    add "%nl%%nl%Onto one’s nightmares;" to {_p2}

    set {_p3} to ""
    add "O Night, why thou crave to bring nightmares into moonlight?" to {_p3}
    add "%nl%%nl%The Night is grim and chaseful;" to {_p3}
    add "%nl%%nl%The Sun is burning and vengeful;" to {_p3}
    add "%nl%%nl%Why thou seek more?" to {_p3}

    set {_p4} to ""
    add "%nl%%nl%%nl%%nl%%nl%%nl%%{_c}%&lAnother God." to {_p4}

    set {_p5} to ""
    add "A new revelation," to {_p5}
    add "%nl%Another cosmos;" to {_p5}
    add "%nl%Friend or foe?" to {_p5}
    add "%nl%%nl%Laid from thy black egg of darkness;" to {_p5}
    add "%nl%Will it bring calamity or harness?" to {_p5}

    set {_p6} to ""
    add "Will thy offspring bring order long lost?" to {_p6}
    add "%nl%%nl%Or will it crush us with heaven's force?" to {_p6}

    set {_p7} to ""
    add "When the heart of the Sun sits on the lava bed;" to {_p7}
    add "%nl%%nl%When the egg of the Night is shone nether red;" to {_p7}
    add "%nl%%nl%When both Moon and Sun have bled;" to {_p7}
    add "%nl%%nl%When the forces of nature are dead;" to {_p7}

    set {_p8} to ""
    add "%{_c}%&lO death;&r" to {_p8}
    add "%nl%Bring us an era of rebirth; shed light to the caves;" to {_p8}
    add "%nl%%nl%%{_c}%&lO death;&r" to {_p8}
    add "%nl%Reveal truth of lies deep rooted;" to {_p8}
    add "%nl%%nl%%{_c}%&lO death;&r" to {_p8}
    add "%nl%Spare us of calamities unbeknown;" to {_p8}

    set {_p9} to ""
    add "For our life was riddled with your name from before we had our own;" to {_p9}
    add "%nl%%nl%Ringing; Thumping; Shouting;" to {_p9}
    add "%nl%%nl%%{_c}%&lMa’at." to {_p9}

    set page 1 of {_book} to {_p1}
    set page 2 of {_book} to {_p2}
    set page 3 of {_book} to {_p3}
    set page 4 of {_book} to {_p4}
    set page 5 of {_book} to {_p5}
    set page 6 of {_book} to {_p6}
    set page 7 of {_book} to {_p7}
    set page 8 of {_book} to {_p8}
    set page 9 of {_book} to {_p9}

    give {_book} to {_p}
