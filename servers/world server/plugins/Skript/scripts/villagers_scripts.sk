function spawn_villager_safe(loc: location):
    # 1. Spawn the villager
    spawn villager at {_loc}
    set {_v} to last spawned villager

    # 2. Set Stats (Level 2, Desert, etc.)
    set max health of {_v} to (max health of {_v} * 2)
    heal {_v}
    add nbt compound from "{VillagerData:{profession:""minecraft:librarian"",level:2,type:""minecraft:desert""},PlayerCreated:0b}" to nbt of {_v}

    # 3. WIPE TRADES (This fixes the '1 Emerald' price bug)
    delete tag "Offers" of nbt of {_v}

    # 4. Construct New Trades
    set {_trades} to "{Recipes:["
    
    # Trade 1: 32 Emeralds -> 1 Totem
    add "{buy:{id:""minecraft:emerald"",Count:32b},sell:{id:""minecraft:totem_of_undying"",Count:1b},maxUses:6,rewardExp:1b,priceMultiplier:0.0f}," to {_trades}
    
    # Trade 2: Diamond + Book -> Sharpness V
    add "{buy:{id:""minecraft:diamond"",Count:1b},buyB:{id:""minecraft:book"",Count:1b},sell:{id:""minecraft:enchanted_book"",Count:1b,tag:{StoredEnchantments:[{id:""minecraft:sharpness"",lvl:5s}]}},maxUses:9999,rewardExp:1b,priceMultiplier:0.0f}" to {_trades}
    
    # FIX: Only close the List [ and the Recipe {
    add "]}" to {_trades}

    # 5. Apply to 'Offers' tag
    add nbt compound from "{Offers:%{_trades}%}" to nbt of {_v}
    
    set name of {_v} to "&6Artifact Trader"
    send "&aSpawned custom trader!" to console

# IMPORTANT: Make sure your command calls the NEW function name:
command /spawn_villager:
    permission: op
    trigger:
        set {_x} to x-coord of player
        set {_y} to y-coord of player
        set {_z} to z-coord of player
        execute console command "/summon villager %{_x}% %{_y}% %{_z}% {VillagerData:{level:2,profession:""minecraft:librarian"",type:""minecraft:desert""},Offers:{Recipes:[{maxUses:6,buy:{id:""minecraft:emerald"",count:32},sell:{id:""minecraft:totem_of_undying"",count:1}},{maxUses:40,buy:{id:""minecraft:paper"",count:16},sell:{id:""minecraft:emerald"",count:1}}]}}"
        # spawn villager at location of player
        set {_v} to last spawned villager

        # 2. Set Stats (Level 2, Desert, etc.)
        set max health of {_v} to (max health of {_v} * 2)


function spawn_guard(loc: location):
    # PlayerCreated:0b makes it patrol the village and not wander off
    # I also gave it 200 HP (Double normal) just in case you want it tough
    set {_nbt} to "{PlayerCreated:0b,Attributes:[{Name:""generic.max_health"",Base:200.0f}],Health:200.0f}"
    
    spawn iron golem at {_loc} with nbt nbt compound from {_nbt}

command /spawn_golem:
    permission: op
    trigger:
        spawn_guard(location of player)
#
command /give_loot_smith:
    permission: op
    trigger:
        if chance of 70%:
            give (random integer between 1 and 3) of coal to player
        
        if chance of 60%:
            give (random integer between 1 and 3) of iron ingot to player
        
        if chance of 50%:
            give (random integer between 2 and 5) of stick to player
        
        if chance of 25%:
            give 1 iron pickaxe to player
        
        if chance of 5%:
            give 1 diamond to player
            
        send "&7Received Smith loot."

command /give_loot_butcher:
    permission: op
    trigger:
        if chance of 70%:
            add (random integer between 1 and 3) of beef to player's inventory
            
        # if chance of 60%:
        #     add (random integer between 1 and 3) of pork to player's inventory
            
        if chance of 50%:
            add (random integer between 2 and 5) of chicken to player's inventory
            
        if chance of 30%:
            add (random integer between 1 and 3) of coal to player's inventory
            
        if chance of 25%:
            add (random integer between 1 and 2) of cooked beef to player's inventory
            
        if chance of 5%:
            add 1 rabbit stew to player's inventory
            
        send "&7Received Butcher loot."

command /give_loot_fletcher:
    permission: op
    trigger:
        if chance of 70%:
            add (random integer between 2 and 6) of stick to player's inventory

        if chance of 60%:
            add (random integer between 1 and 4) of feather to player's inventory

        if chance of 50%:
            add (random integer between 1 and 3) of flint to player's inventory

        if chance of 40%:
            add (random integer between 2 and 5) of arrow to player's inventory

        if chance of 30%:
            add (random integer between 1 and 3) of string to player's inventory

        if chance of 20%:
            add 1 bow to player's inventory

        if chance of 5%:
            add 1 crossbow to player's inventory

        send "&7Received Fletcher loot."
